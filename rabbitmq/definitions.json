{
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": ["administrator"]
    }
  ],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "queues": [
    {
      "name": "audit_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum"
      }
    },
    {
      "name": "peripheral_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum"
      }
    },
    {
      "name": "vector_logs_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "vector_metrics_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "vector_telemetry_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "controller_status_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum"
      }
    },
    {
      "name": "controller_feedback_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum"
      }
    }
  ],
  "bindings": [
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "audit_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.audit.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "audit_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.status.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "peripheral_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.peripheral.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "vector_logs_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.logs.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "vector_metrics_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.metrics.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "vector_telemetry_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.telemetry.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "controller_status_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.status.up",
