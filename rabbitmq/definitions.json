    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "controller_feedback_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.control.up",
      "arguments": {}
    },
    {
      "source": "amq.topic",
      "vhost": "/",
      "destination": "controller_feedback_queue",
      "destination_type": "queue",
      "routing_key": "mqttsystem.org1.*.ota.up",
      "arguments": {}
